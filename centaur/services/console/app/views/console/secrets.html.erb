<% content_for :title, "Secrets · Centaur Console" %>

<% total = @secrets_by_kind.values.sum(&:size) %>

<%= render "control_tabs" %>

<% add_secret_action = capture do %>
  <div class="relative" data-controller="dropdown">
    <button type="button" data-action="dropdown#toggle" class="btn-primary">
      + Add Secret
    </button>
    <div data-dropdown-target="menu" hidden
         class="absolute right-0 z-20 mt-2 w-48 overflow-hidden rounded-lg border border-ink-600 bg-ink-850 shadow-xl">
      <% secret_form_kinds.each do |_slug, cfg| %>
        <a href="<%= new_polymorphic_path([ :console, cfg[:model].new ]) %>"
           class="block px-4 py-2 text-sm text-zinc-300 transition-colors hover:bg-centaur-500/[0.08] hover:text-centaur-300"><%= cfg[:label] %></a>
      <% end %>
    </div>
  </div>
<% end %>

<%= render "console/page_header",
           title: "Secrets",
           subtitle: "#{pluralize(total, "secret")} across #{@secrets_by_kind.size} kinds.",
           actions: add_secret_action %>

<div class="space-y-10">
  <% @secrets_by_kind.each do |kind, records| %>
    <section>
      <div class="mb-3 flex items-center gap-3">
        <h2 class="text-sm font-semibold text-zinc-200"><%= secret_kind_label(kind) %></h2>
        <span class="rounded-full bg-ink-700 px-2 py-0.5 text-xs text-zinc-400"><%= records.size %></span>
      </div>

      <% if records.empty? %>
        <p class="empty-state">No <%= secret_kind_label(kind).downcase %> secrets.</p>
      <% else %>
        <div class="console-scroll-panel">
          <table class="console-table">
            <thead class="console-table-head">
              <tr>
                <th class="console-th">ID</th>
                <th class="console-th">Name</th>
                <th class="console-th">Source</th>
                <th class="console-th">Labels</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-ink-700">
              <% records.each do |s| %>
                <tr class="align-middle console-row-hover">
                  <td class="console-td-nowrap">
                    <% if s.foreign_id.present? %>
                      <%= link_to truncate_middle(s.foreign_id), console_secret_path(kind, s.oid), class: "console-link", title: s.foreign_id %>
                      <%= id_meta_line(s.namespace, oid: s.oid) %>
                    <% else %>
                      <%= link_to s.oid, console_secret_path(kind, s.oid), class: "console-link" %>
                      <%= id_meta_line(s.namespace) %>
                    <% end %>
                  </td>
                  <td class="console-td-nowrap">
                    <% name = s.try(:name).presence %>
                    <% if name %>
                      <span class="text-zinc-100" title="<%= name %>"><%= truncate_middle(name) %></span>
                    <% else %>
                      <span class="text-zinc-600">unnamed</span>
                    <% end %>
                    <% if (cred = managed_credential(s)) %>
                      <span class="ml-2 inline-flex items-center rounded bg-centaur-500/10 px-1.5 py-0.5 text-[11px] text-centaur-300 ring-1 ring-centaur-500/30"
                            title="Managed by the <%= cred.oauth_app&.slug %> OAuth integration">managed</span>
                    <% end %>
                  </td>
                  <td class="console-td-nowrap">
                    <% types = secret_source_types(s) %>
                    <% if types.any? %>
                      <div class="flex gap-1">
                        <% types.each do |type| %>
                          <span class="rounded bg-ink-700 px-2 py-0.5 text-[11px] uppercase tracking-wide text-zinc-300"><%= type %></span>
                        <% end %>
                      </div>
                    <% else %>
                      <span class="text-zinc-600">—</span>
                    <% end %>
                  </td>
                  <td class="console-td">
                    <% if s.labels.present? %>
                      <div class="flex flex-wrap gap-1">
                        <% s.labels.each do |k, v| %>
                          <span class="label-chip"><%= k %>=<%= v %></span>
                        <% end %>
                      </div>
                    <% else %>
                      <span class="text-zinc-600">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
