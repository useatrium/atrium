{
  "name": "atrium-surface",
  "private": true,
  "version": "0.1.0",
  "description": "Atrium product workspace",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @atrium/server dev\" \"pnpm --filter @atrium/web dev\"",
    "e2e": "pnpm --filter @atrium/e2e e2e",
    "lint": "biome check . --diagnostic-level=error",
    "lint:fix": "biome check --write .",
    "migrate": "pnpm --filter @atrium/server migrate",
    "check:migrations": "node server/scripts/check-migration-filenames.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm lint && pnpm check:migrations && pnpm typecheck && pnpm test",
    "ws-smoke": "node scripts/ws-smoke.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "concurrently": "^9.1.2",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "overrides": {
      "fbjs>ua-parser-js": "2.0.10",
      "react-native-markdown-display>markdown-it": "14.2.0",
      "react-native-syntax-highlighter>react-syntax-highlighter": "16.1.1",
      "undici@6": "6.27.0",
      "undici@7": "7.28.0",
      "esbuild": "0.28.1",
      "shell-quote": "1.8.4",
      "xcode>uuid": "11.1.1"
    },
    "patchedDependencies": {
      "react-native-syntax-highlighter@2.1.0": "patches/react-native-syntax-highlighter@2.1.0.patch"
    }
  }
}
