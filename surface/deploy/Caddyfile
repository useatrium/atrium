# Scenario A, always-on Mac behind Tailscale:
#   SITE_ADDRESS=:80
#   HTTP_HOST_PORT=8080 or 80
#   Mobile app server URL: http://<tailscale-ip-or-magicdns-name>:<HTTP_HOST_PORT>
#
# Scenario B, Linux VPS with automatic TLS:
#   SITE_ADDRESS=atrium.example.com
#   HTTP_HOST_PORT=80
#   HTTPS_HOST_PORT=443
#   Mobile app server URL: https://atrium.example.com
#
# Caddy reverse_proxy supports WebSocket upgrades automatically.

# handle blocks are mutually exclusive — without them try_files (a rewrite,
# which runs before reverse_proxy in Caddy's directive order) rewrites API
# paths to /index.html before the proxy matcher can see them.
{$SITE_ADDRESS:localhost} {
	encode zstd gzip

	@server path /api/* /auth/* /ws /healthz
	handle @server {
		reverse_proxy server:3001
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
