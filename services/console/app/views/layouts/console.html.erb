<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= content_for(:title) || "Centaur Console" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <link rel="icon" href="/icon-dark.svg" type="image/svg+xml" data-console-favicon>
    <script>
      (() => {
        const storageKey = "centaur-console-theme";
        const storageSourceKey = "centaur-console-theme-source";
        const validTheme = (theme) => theme === "light" || theme === "dark";
        const systemTheme = () => {
          if (window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches) {
            return "light";
          }
          return "dark";
        };
        const storedTheme = () => {
          try {
            const theme = localStorage.getItem(storageKey);
            const source = localStorage.getItem(storageSourceKey);
            return source === "manual" && validTheme(theme) ? theme : null;
          } catch (_error) {
            return null;
          }
        };
        const resolveTheme = () => storedTheme() || systemTheme();
        const applyTheme = (theme) => {
          const nextTheme = validTheme(theme) ? theme : systemTheme();
          document.documentElement.dataset.consoleTheme = nextTheme;

          const favicon = document.querySelector("[data-console-favicon]");
          if (favicon) {
            favicon.setAttribute("href", nextTheme === "light" ? "/icon-light.svg" : "/icon-dark.svg");
          }

          return nextTheme;
        };

        window.ConsoleTheme = {
          apply: applyTheme,
          persist: (theme) => {
            const nextTheme = applyTheme(theme);
            try {
              localStorage.setItem(storageKey, nextTheme);
              localStorage.setItem(storageSourceKey, "manual");
            } catch (_error) {
              // Theme still applies for this page load when storage is unavailable.
            }
            return nextTheme;
          },
          resolve: resolveTheme
        };

        applyTheme(resolveTheme());

        if (window.matchMedia) {
          const mediaQuery = window.matchMedia("(prefers-color-scheme: light)");
          const syncSystemTheme = () => {
            if (!storedTheme()) applyTheme(resolveTheme());
          };

          if (typeof mediaQuery.addEventListener === "function") {
            mediaQuery.addEventListener("change", syncSystemTheme);
          } else if (typeof mediaQuery.addListener === "function") {
            mediaQuery.addListener(syncSystemTheme);
          }
        }
      })();
    </script>

    <%# Tailwind is compiled by the standalone binary into app/assets/builds/tailwind.css.
        See config/tailwind.config.js for the centaur/ink palette and radii overrides. %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      ::selection { background: #28c26a; color: #050506; }
      html[data-console-theme="dark"] { color-scheme: dark; }
      html[data-console-theme="light"] { color-scheme: light; }
      .glow { filter: drop-shadow(0 0 14px rgba(40,194,106,0.45)); }
      *::-webkit-scrollbar { width: 10px; height: 10px; }
      *::-webkit-scrollbar-track { background: #0b0b0d; }
      *::-webkit-scrollbar-thumb { background: #33333a; border-radius: 1px; }
      *::-webkit-scrollbar-thumb:hover { background: #28c26a; }

      .console-shell {
        display: flex;
        height: 100%;
        overflow: hidden;
        background: #050506;
      }

      .console-sidebar {
        width: 18rem;
        flex: 0 0 auto;
        display: flex;
        min-height: 0;
        flex-direction: column;
        border-right: 1px solid rgba(255, 255, 255, 0.07);
        background: #070708;
        transition: width 160ms ease;
      }

      .console-sidebar-top {
        display: flex;
        height: 3.5rem;
        align-items: center;
        gap: 0.75rem;
        padding: 0 1.5rem;
      }

      .console-brand {
        display: flex;
        min-width: 0;
        flex: 1;
        align-items: center;
        color: #f4f4f5;
      }

      .console-brand img {
        height: 1.75rem;
        width: auto;
      }

      .console-brand-glyph {
        display: none;
        height: 2rem;
        width: 2rem;
        place-items: center;
        border-radius: 0.5rem;
      }

      .console-brand-glyph img {
        height: 1.75rem;
        width: 1.75rem;
        object-fit: contain;
      }

      .console-sidebar-scroll {
        min-height: 0;
        flex: 1;
        overflow-y: auto;
        padding: 0.25rem 0.75rem 1rem;
      }

      .console-nav-list {
        display: grid;
        gap: 0.125rem;
        margin-bottom: 0.125rem;
      }

      .console-nav-link {
        display: flex;
        min-width: 0;
        height: 2.35rem;
        align-items: center;
        gap: 0.625rem;
        border-radius: 0.875rem;
        padding: 0 0.875rem;
        color: #a1a1aa;
        text-decoration: none;
        transition: background 120ms ease, color 120ms ease;
      }

      .console-nav-link:hover {
        background: rgba(255, 255, 255, 0.045);
        color: #f4f4f5;
      }

      .console-nav-link-active {
        background: rgba(255, 255, 255, 0.07);
        color: #3ace79;
      }

      .console-nav-icon {
        display: grid;
        width: 1rem;
        flex: 0 0 auto;
        place-items: center;
        color: currentColor;
      }

      .console-nav-label {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.875rem;
        font-weight: 500;
      }

      .console-thread-group-title {
        display: flex;
        height: 2.35rem;
        align-items: center;
        gap: 0.625rem;
        border-radius: 0.875rem;
        padding: 0 0.875rem;
        color: #a1a1aa;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: background 120ms ease, color 120ms ease;
      }

      .console-thread-group-title:hover {
        background: rgba(255, 255, 255, 0.045);
        color: #f4f4f5;
      }

      .console-thread-group-title-active {
        background: rgba(255, 255, 255, 0.07);
        color: #3ace79;
      }

      .console-thread-list {
        display: grid;
        gap: 0.3rem;
        margin-top: 0.3rem;
      }

      .console-thread-link {
        position: relative;
        display: grid;
        min-width: 0;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 0.5rem;
        border-radius: 0.875rem;
        padding: 0.55rem 0.75rem 0.55rem 2.5rem;
        color: #d4d4d8;
        text-decoration: none;
        transition: background 120ms ease, color 120ms ease;
      }

      /* An open thread: bright title plus a marker in the indent gutter — no
         filled pill on thread rows. A single open thread gets a dot; once a
         second pane opens, rows carry data-console-pane-index and the marker
         becomes the pane number in grid order. */
      .console-thread-link-open {
        color: #f4f4f5;
      }

      .console-thread-link-open::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 1.35rem;
        height: 0.3rem;
        width: 0.3rem;
        transform: translateY(-50%);
        border-radius: 999px;
        background: #28c26a;
      }

      .console-thread-link-open[data-console-pane-index]::before {
        content: attr(data-console-pane-index);
        left: 1.05rem;
        height: auto;
        width: auto;
        border-radius: 0;
        background: none;
        color: #3ace79;
        font-size: 0.6875rem;
        font-weight: 700;
        line-height: 1;
      }

      .console-thread-link:hover {
        background: rgba(255, 255, 255, 0.045);
        color: #f4f4f5;
      }

      .console-thread-link-active {
        background: rgba(255, 255, 255, 0.07);
        color: #f4f4f5;
      }

      .console-thread-link-hidden {
        display: none;
      }

      .console-thread-title {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.875rem;
        font-weight: 500;
      }

      .console-thread-time {
        color: #71717a;
        font-size: 0.75rem;
      }

      .console-panel-close {
        display: grid;
        height: 1.75rem;
        width: 1.75rem;
        flex: 0 0 auto;
        place-items: center;
        border-radius: 0.5rem;
        color: #71717a;
        transition: background 120ms ease, color 120ms ease;
      }

      .console-panel-close:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #f4f4f5;
      }

      .console-thinking {
        min-width: 0;
        border-left: 2px solid rgba(255, 255, 255, 0.12);
        padding-left: 0.875rem;
      }

      .console-thinking-summary {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 0.375rem;
        cursor: pointer;
        list-style: none;
        user-select: none;
        color: #71717a;
        font-size: 0.75rem;
      }

      .console-thinking-summary::-webkit-details-marker {
        display: none;
      }

      .console-thinking-summary:hover {
        color: #a1a1aa;
      }

      .console-thinking-chevron {
        display: grid;
        flex: 0 0 auto;
        place-items: center;
        transition: transform 120ms ease;
      }

      .console-thinking[open] .console-thinking-chevron {
        transform: rotate(90deg);
      }

      .console-thinking-preview {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-style: italic;
        color: #5f6068;
      }

      .console-thinking[open] .console-thinking-preview {
        display: none;
      }

      .console-thinking-body {
        margin-top: 0.5rem;
        color: #8b8b94;
      }

      .console-thread-empty,
      .console-thread-show-all {
        display: block;
        width: 100%;
        cursor: pointer;
        padding: 0.45rem 0.75rem 0.45rem 2.5rem;
        color: #71717a;
        font-size: 0.8125rem;
        text-decoration: none;
        text-align: left;
      }

      .console-thread-show-all:hover {
        color: #a1a1aa;
      }

      .console-thread-show-all[hidden] {
        display: none;
      }

      .console-sidebar-account {
        position: relative;
        border-top: 1px solid rgba(255, 255, 255, 0.07);
      }

      .console-account-button {
        display: flex;
        height: 3.625rem;
        min-width: 0;
        width: 100%;
        cursor: pointer;
        align-items: center;
        gap: 0.625rem;
        padding: 0 1.5rem;
        text-align: left;
        transition: background 120ms ease, color 120ms ease;
      }

      .console-account-button:hover,
      .console-account-button[aria-expanded="true"] {
        background: rgba(255, 255, 255, 0.045);
      }

      .console-user-avatar {
        display: grid;
        height: 1.75rem;
        width: 1.75rem;
        flex: 0 0 auto;
        place-items: center;
        border-radius: 999px;
        background: rgba(40, 194, 106, 0.16);
        color: #93e7b7;
        font-size: 0.75rem;
        font-weight: 700;
      }

      .console-account-email {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #71717a;
        font-size: 0.75rem;
      }

      .console-account-menu {
        position: absolute;
        right: 0.75rem;
        bottom: 4.125rem;
        left: 0.75rem;
        z-index: 30;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.11);
        border-radius: 0.875rem;
        background: #101012;
        padding: 0.5rem;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.4);
      }

      .console-account-menu[hidden] {
        display: none;
      }

      .console-account-menu-line {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        padding: 0.5rem 0.625rem;
        color: #8b8b94;
        font-size: 0.75rem;
      }

      .console-account-menu-muted {
        color: #5f6068;
      }

      .console-account-menu-separator {
        height: 1px;
        margin: 0.375rem 0.25rem;
        background: rgba(255, 255, 255, 0.08);
      }

      .console-account-menu form {
        margin: 0;
      }

      .console-account-menu-button,
      .console-signout-button {
        display: flex;
        height: 2.25rem;
        width: 100%;
        cursor: pointer;
        align-items: center;
        justify-content: flex-start;
        gap: 0.5rem;
        border-radius: 0.625rem;
        padding: 0 0.625rem;
        color: #a1a1aa;
        font: inherit;
        font-size: 0.875rem;
        font-weight: 500;
        line-height: 1.25rem;
        transition: background 120ms ease, color 120ms ease;
      }

      .console-account-menu-button:hover,
      .console-signout-button:hover {
        background: rgba(255, 255, 255, 0.055);
        color: #f4f4f5;
      }

      .console-main {
        display: flex;
        height: 100%;
        min-width: 0;
        min-height: 0;
        flex: 1;
        flex-direction: column;
        overflow-y: auto;
      }

      .console-main-threads {
        overflow: hidden;
      }

      .console-main-page {
        width: 100%;
        max-width: 80rem;
        margin: 0 auto;
        padding: 1.35rem 2rem 2.5rem;
      }

      .console-main-thread-frame {
        display: flex;
        flex: 1;
        min-height: 0;
        overflow: hidden;
        flex-direction: column;
        padding: 1.35rem 2rem 0;
      }

      .console-thread-content {
        width: 100%;
        max-width: 52rem;
        margin-left: auto;
        margin-right: auto;
      }

      .console-thread-detail-header {
        display: flex;
        justify-content: center;
        flex: 0 0 auto;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .console-thread-detail-header > .console-thread-content,
      #thread-transcript-scroll > .console-thread-content {
        flex: 0 0 auto;
      }

      /* Transcript scroll containers hold a single content child inside a
         column-reverse flex, which makes the scroll origin the bottom: threads
         open already scrolled to the newest message, with no post-render JS
         jump and no reflow drift when webfonts land. */
      .console-transcript-scroll {
        display: flex;
        flex-direction: column-reverse;
      }

      #thread-transcript-scroll {
        align-items: center;
        /* Reserve symmetric scrollbar gutters so the centered transcript
           column lines up with the (non-scrolling) header above it. */
        scrollbar-gutter: stable both-edges;
      }

      .console-markdown {
        min-width: 0;
      }

      .console-markdown-link {
        overflow-wrap: anywhere;
        word-break: normal;
      }

      .console-message-stack {
        min-width: 0;
      }

      .console-message-timestamp {
        min-height: 1.25rem;
        padding-top: 0.375rem;
        color: #71717a;
        font-size: 0.75rem;
        line-height: 0.875rem;
        opacity: 0;
        transition: opacity 120ms ease;
      }

      .group:hover .console-message-timestamp,
      .group:focus-within .console-message-timestamp {
        opacity: 1;
      }

      .console-control-tabs {
        display: flex;
        gap: 0.25rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .console-control-tab {
        margin-bottom: -1px;
        padding: 0.625rem 0.75rem;
        border-bottom: 1px solid transparent;
        color: #a1a1aa;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 120ms ease, color 120ms ease;
      }

      .console-control-tab:hover {
        color: #f4f4f5;
      }

      .console-control-tab-active {
        border-color: #28c26a;
        color: #3ace79;
      }

      .console-run-row {
        background: rgba(11, 11, 13, 0.45);
        color: #71717a;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.025);
      }

      .console-run-status {
        color: #d4d4d8;
      }

      .console-run-id {
        color: #52525b;
      }

      html[data-console-theme="light"] ::selection {
        background: rgba(40, 194, 106, 0.22);
        color: #1f2428;
      }

      html[data-console-theme="light"] *::-webkit-scrollbar-track {
        background: #f3f3ef;
      }

      html[data-console-theme="light"] *::-webkit-scrollbar-thumb {
        background: #c9cbc5;
      }

      html[data-console-theme="light"] *::-webkit-scrollbar-thumb:hover {
        background: #28a65d;
      }

      html[data-console-theme="light"] body,
      html[data-console-theme="light"] .console-shell,
      html[data-console-theme="light"] .console-main,
      html[data-console-theme="light"] .console-main-page,
      html[data-console-theme="light"] .console-main-thread-frame {
        background: #f6f6f2;
        color: #303438;
      }

      html[data-console-theme="light"] .console-sidebar {
        border-right-color: #deded7;
        background: #fbfbf8;
      }

      html[data-console-theme="light"] .console-sidebar-account {
        border-top-color: #deded7;
      }

      html[data-console-theme="light"] .console-brand {
        color: #24272b;
      }

      html[data-console-theme="light"] .console-brand-lockup img,
      html[data-console-theme="light"] .console-brand-glyph img {
        filter: invert(1) drop-shadow(0 0 14px rgba(40, 194, 106, 0.14));
      }

      html[data-console-theme="light"] .console-nav-link,
      html[data-console-theme="light"] .console-thread-group-title,
      html[data-console-theme="light"] .console-account-menu-button,
      html[data-console-theme="light"] .console-signout-button {
        color: #5f656c;
      }

      html[data-console-theme="light"] .console-nav-link:hover,
      html[data-console-theme="light"] .console-thread-group-title:hover,
      html[data-console-theme="light"] .console-thread-link:hover,
      html[data-console-theme="light"] .console-account-button:hover,
      html[data-console-theme="light"] .console-account-button[aria-expanded="true"],
      html[data-console-theme="light"] .console-account-menu-button:hover,
      html[data-console-theme="light"] .console-signout-button:hover {
        background: #edede8;
        color: #24272b;
      }

      html[data-console-theme="light"] .console-nav-link-active,
      html[data-console-theme="light"] .console-thread-group-title-active,
      html[data-console-theme="light"] .console-thread-link-active {
        background: #e7eee8;
        color: #168f4a;
      }

      html[data-console-theme="light"] .console-thread-link {
        color: #303438;
      }

      html[data-console-theme="light"] .console-thread-link-open {
        color: #24272b;
      }

      html[data-console-theme="light"] .console-thread-link-open::before {
        background: #28a65d;
      }

      html[data-console-theme="light"] .console-thread-link-open[data-console-pane-index]::before {
        background: none;
        color: #168f4a;
      }

      html[data-console-theme="light"] .console-thread-time,
      html[data-console-theme="light"] .console-thread-empty,
      html[data-console-theme="light"] .console-thread-show-all,
      html[data-console-theme="light"] .console-account-email,
      html[data-console-theme="light"] .console-page-meta {
        color: #7a7f86;
      }

      html[data-console-theme="light"] .console-thread-show-all:hover {
        color: #303438;
      }

      html[data-console-theme="light"] .console-panel-close {
        color: #7a7f86;
      }

      html[data-console-theme="light"] .console-panel-close:hover {
        background: #e8e9e3;
        color: #24272b;
      }

      html[data-console-theme="light"] .console-thinking {
        border-left-color: #d8d8d0;
      }

      html[data-console-theme="light"] .console-thinking-summary {
        color: #7a7f86;
      }

      html[data-console-theme="light"] .console-thinking-summary:hover {
        color: #303438;
      }

      html[data-console-theme="light"] .console-thinking-preview {
        color: #8c9198;
      }

      html[data-console-theme="light"] .console-thinking-body {
        color: #565c63;
      }

      html[data-console-theme="light"] .console-user-avatar {
        background: #dff2e7;
        color: #12733f;
      }

      html[data-console-theme="light"] .console-account-menu {
        border-color: #d8d8d0;
        background: #ffffff;
        box-shadow: 0 18px 45px rgba(31, 36, 40, 0.12);
      }

      html[data-console-theme="light"] .console-account-menu-line {
        color: #5f656c;
      }

      html[data-console-theme="light"] .console-account-menu-muted {
        color: #8a8f96;
      }

      html[data-console-theme="light"] .console-account-menu-separator {
        background: #e5e5de;
      }

      html[data-console-theme="light"] .console-control-tabs {
        border-bottom-color: #deded7;
      }

      html[data-console-theme="light"] .console-thread-detail-header {
        border-bottom-color: #deded7;
      }

      html[data-console-theme="light"] .console-control-tab {
        color: #6b7078;
      }

      html[data-console-theme="light"] .console-control-tab:hover {
        color: #24272b;
      }

      html[data-console-theme="light"] .console-control-tab-active {
        border-color: #28a65d;
        color: #168f4a;
      }

      html[data-console-theme="light"] .console-run-row {
        background: #ffffff;
        color: #6f757c;
        box-shadow: inset 0 0 0 1px #deded7;
      }

      html[data-console-theme="light"] .console-run-status {
        color: #303438;
      }

      html[data-console-theme="light"] .console-run-id {
        color: #7a7f86;
      }

      html[data-console-theme="light"] .form-section,
      html[data-console-theme="light"] .console-panel,
      html[data-console-theme="light"] .console-scroll-panel {
        border-color: #deded7;
        background: #ffffff;
      }

      html[data-console-theme="light"] .console-table-head {
        background: #f0f0eb;
        color: #7a7f86;
      }

      html[data-console-theme="light"] .console-table > :not(:last-child) {
        border-color: #e6e5de;
      }

      html[data-console-theme="light"] .form-input {
        border-color: #d2d3cc;
        background: #ffffff;
        color: #24272b;
      }

      html[data-console-theme="light"] .form-input::placeholder,
      html[data-console-theme="light"] .placeholder-zinc-500::placeholder,
      html[data-console-theme="light"] .placeholder-zinc-600::placeholder {
        color: #8c9198;
      }

      html[data-console-theme="light"] .btn-secondary {
        border-color: #d2d3cc;
        color: #5f656c;
      }

      html[data-console-theme="light"] .empty-state {
        border-color: #d8d8d0;
        background: #f0f0eb;
        color: #8c9198;
      }

      html[data-console-theme="light"] .console-link,
      html[data-console-theme="light"] .text-centaur-300,
      html[data-console-theme="light"] .text-centaur-400,
      html[data-console-theme="light"] .text-centaur-500 {
        color: #168f4a;
      }

      html[data-console-theme="light"] .bg-ink-950,
      html[data-console-theme="light"] .bg-ink-950\/15,
      html[data-console-theme="light"] .bg-ink-950\/35,
      html[data-console-theme="light"] .bg-ink-900,
      html[data-console-theme="light"] .bg-ink-900\/25,
      html[data-console-theme="light"] .bg-ink-900\/35,
      html[data-console-theme="light"] .bg-ink-900\/80 {
        background-color: #f6f6f2;
      }

      html[data-console-theme="light"] .bg-ink-850,
      html[data-console-theme="light"] .bg-ink-850\/40,
      html[data-console-theme="light"] .bg-ink-850\/50,
      html[data-console-theme="light"] .bg-ink-850\/60,
      html[data-console-theme="light"] .bg-ink-850\/70,
      html[data-console-theme="light"] .bg-ink-850\/80,
      html[data-console-theme="light"] .bg-ink-800,
      html[data-console-theme="light"] .bg-ink-800\/60,
      html[data-console-theme="light"] .bg-ink-800\/80,
      html[data-console-theme="light"] .bg-ink-700,
      html[data-console-theme="light"] .bg-ink-700\/60 {
        background-color: #ffffff;
      }

      html[data-console-theme="light"] .bg-ink-600 {
        background-color: #e8e9e3;
      }

      html[data-console-theme="light"] .border-ink-500,
      html[data-console-theme="light"] .border-ink-600,
      html[data-console-theme="light"] .border-ink-600\/80,
      html[data-console-theme="light"] .border-ink-700 {
        border-color: #deded7;
      }

      html[data-console-theme="light"] .ring-ink-500,
      html[data-console-theme="light"] .ring-ink-600 {
        --tw-ring-color: #d8d8d0;
      }

      html[data-console-theme="light"] .divide-ink-600 > :not([hidden]) ~ :not([hidden]),
      html[data-console-theme="light"] .divide-ink-700 > :not([hidden]) ~ :not([hidden]) {
        border-color: #deded7;
      }

      html[data-console-theme="light"] .text-zinc-50,
      html[data-console-theme="light"] .text-zinc-100,
      html[data-console-theme="light"] .text-zinc-200,
      html[data-console-theme="light"] .text-zinc-300 {
        color: #303438;
      }

      html[data-console-theme="light"] .text-zinc-400 {
        color: #565c63;
      }

      html[data-console-theme="light"] .text-zinc-500 {
        color: #6f757c;
      }

      html[data-console-theme="light"] .text-zinc-600 {
        color: #8c9198;
      }

      @media (max-width: 760px) {
        .console-sidebar {
          width: 11rem;
        }

        .console-brand-lockup,
        .console-account-details {
          display: none;
        }

        .console-brand-glyph {
          display: grid;
        }

        .console-sidebar-top {
          justify-content: center;
          padding: 0;
        }

        .console-main-page {
          padding: 1rem 1rem 1.5rem;
        }

        .console-main-thread-frame {
          padding: 1rem 1rem 0;
        }

      }
    </style>
  </head>

  <% threads_view = request.path.start_with?("/console/threads") %>
  <%# The Control and Data Sync sections are admin-only (each controller enforces
      require_admin server-side); non-admins only get the Chats view below. %>
  <% nav_items = [] %>
  <% if current_user&.admin? %>
    <% control_matches = [ "/console/principals", "/console/roles", "/console/secrets", "/console/credentials", "/console/oauth_apps", "/console/users" ] %>
    <% nav_items = [
      { label: "Control", icon: "shield-check", path: console_principals_path, matches: control_matches, root_active: true },
      { label: "Data Sync", icon: "database", path: console_etls_path, matches: [ "/console/etls" ] }
    ] %>
  <% end %>

  <body class="h-full overflow-hidden bg-ink-900 text-zinc-300 font-mono antialiased">
    <div id="console-shell" class="console-shell">
      <aside class="console-sidebar" aria-label="Console navigation">
        <div class="console-sidebar-top">
          <a href="<%= root_path %>" class="console-brand" aria-label="Centaur Console">
            <span class="console-brand-glyph">
              <%= image_tag "/icon.svg", alt: "", aria: { hidden: true }, width: 275, height: 275 %>
            </span>
            <span class="console-brand-lockup">
              <%= image_tag "centaur-lockup-white.svg", alt: "Centaur", class: "glow", width: 497, height: 127 %>
            </span>
          </a>
        </div>

        <div class="console-sidebar-scroll">
          <nav class="console-nav-list" aria-label="Console sections">
            <% nav_items.each do |item| %>
              <% active = request.path == item[:path] ||
                          item[:matches].any? { |match| request.path.start_with?(match) } ||
                          (item[:root_active] && request.path == root_path) %>
              <a href="<%= item[:path] %>"
                 class="console-nav-link <%= "console-nav-link-active" if active %>"
                 title="<%= item[:label] %>">
                <span class="console-nav-icon"><%= console_icon(item[:icon], classes: "size-4") %></span>
                <span class="console-nav-label"><%= item[:label] %></span>
              </a>
            <% end %>
          </nav>

          <div class="console-thread-group">
            <a href="<%= console_threads_path %>"
               class="console-thread-group-title <%= "console-thread-group-title-active" if threads_view %>"
               title="Chats">
              <span class="console-nav-icon"><%= console_icon("message-square", classes: "size-4") %></span>
              <span class="console-nav-label">Chats</span>
            </a>
            <%# The thread list is loaded lazily via a Turbo Frame so the
                unindexed cross-database sessions query never blocks the primary
                page render. See ApplicationController#init_console_sidebar_threads
                and Console::ThreadsController#sidebar.

                The current thread selection rides along on the frame src so the
                initial out-of-band render can surface and highlight the open
                thread(s). The wrapper div (not the frame itself — a permanent
                turbo-frame trips Turbo's frame lifecycle and can wedge the
                visit progress bar) is turbo-permanent: Turbo Drive carries the
                loaded list across page visits instead of refetching it, so
                thread navigation does not repaint the sidebar; the active
                highlight is re-synced client-side from the page URL. %>
            <div id="console_sidebar_thread_list"
                 class="console-thread-list"
                 data-turbo-permanent>
              <%= turbo_frame_tag "console_sidebar_threads",
                                  src: console_sidebar_threads_path(
                                    thread: (params[:thread].to_s.presence if threads_view)
                                  ),
                                  loading: :lazy do %>
                <div class="console-thread-empty">Loading chats…</div>
              <% end %>
            </div>
          </div>
        </div>

        <% if current_user %>
          <div class="console-sidebar-account" data-account-menu>
            <button type="button"
                    id="console-account-menu-button"
                    class="console-account-button"
                    aria-haspopup="menu"
                    aria-expanded="false"
                    aria-controls="console-account-menu">
              <span class="console-user-avatar"><%= current_user.email.to_s[0].to_s.upcase.presence || "?" %></span>
              <span class="console-account-email console-account-details" title="<%= current_user.email %>"><%= current_user.email %></span>
            </button>
            <div id="console-account-menu"
                 class="console-account-menu"
                 role="menu"
                 aria-labelledby="console-account-menu-button"
                 hidden>
              <div class="console-account-menu-line" title="<%= current_user.email %>"><%= current_user.email %></div>
              <div class="console-account-menu-line console-account-menu-muted">Centaur Console</div>
              <div class="console-account-menu-separator"></div>
              <button type="button"
                      class="console-account-menu-button"
                      data-console-theme-toggle
                      role="menuitem"
                      aria-label="Switch to light mode">
                <span data-console-theme-action-icon="light"><%= console_icon("sun", classes: "size-4") %></span>
                <span data-console-theme-action-icon="dark" hidden><%= console_icon("moon", classes: "size-4") %></span>
                <span data-console-theme-label>Light mode</span>
              </button>
              <%= button_to logout_path,
                    method: :delete,
                    class: "console-signout-button",
                    form: { class: "console-signout-form" },
                    role: "menuitem",
                    title: "Sign out",
                    aria: { label: "Sign out" } do %>
                <%= console_icon("log-out", classes: "size-4") %>
                <span class="console-signout-label">Sign out</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </aside>

      <main class="console-main <%= "console-main-threads" if threads_view %>">
        <div class="<%= threads_view ? "console-main-thread-frame" : "console-main-page" %>">
          <% if flash[:notice] %>
            <div class="mb-6 rounded border border-ink-600 bg-ink-850/60 px-4 py-3 text-sm text-zinc-400"><%= flash[:notice] %></div>
          <% end %>
          <% if flash[:alert] %>
            <div class="alert-error"><%= flash[:alert] %></div>
          <% end %>
          <%= yield %>
        </div>
      </main>
    </div>

    <script>
      (() => {
        const accountButton = document.getElementById("console-account-menu-button");
        const accountMenu = document.getElementById("console-account-menu");
        if (!accountButton || !accountMenu) return;

        const closeAccountMenu = () => {
          accountMenu.hidden = true;
          accountButton.setAttribute("aria-expanded", "false");
        };

        accountButton.addEventListener("click", () => {
          const expanded = accountButton.getAttribute("aria-expanded") === "true";
          accountMenu.hidden = expanded;
          accountButton.setAttribute("aria-expanded", String(!expanded));
        });

        document.addEventListener("click", (event) => {
          if (accountMenu.hidden) return;
          if (accountButton.contains(event.target) || accountMenu.contains(event.target)) return;
          closeAccountMenu();
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") closeAccountMenu();
        });
      })();

      (() => {
        const themeToggle = document.querySelector("[data-console-theme-toggle]");
        if (!themeToggle) return;

        const root = document.documentElement;
        const label = themeToggle.querySelector("[data-console-theme-label]");
        const lightIcon = themeToggle.querySelector("[data-console-theme-action-icon='light']");
        const darkIcon = themeToggle.querySelector("[data-console-theme-action-icon='dark']");

        const syncThemeControl = (theme) => {
          const nextTheme = theme === "light" ? "light" : "dark";
          const isLight = nextTheme === "light";
          if (label) label.textContent = isLight ? "Dark mode" : "Light mode";
          themeToggle.setAttribute(
            "aria-label",
            isLight ? "Switch to dark mode" : "Switch to light mode"
          );
          if (lightIcon) lightIcon.hidden = isLight;
          if (darkIcon) darkIcon.hidden = !isLight;
        };

        const applyTheme = (theme, persist = false) => {
          let nextTheme;
          if (window.ConsoleTheme) {
            nextTheme = persist ? window.ConsoleTheme.persist(theme) : window.ConsoleTheme.apply(theme);
          } else {
            nextTheme = theme === "light" ? "light" : "dark";
            root.dataset.consoleTheme = nextTheme;
          }
          syncThemeControl(nextTheme);
        };

        applyTheme(root.dataset.consoleTheme || window.ConsoleTheme?.resolve?.() || "dark");
        themeToggle.addEventListener("click", () => {
          applyTheme(root.dataset.consoleTheme === "light" ? "dark" : "light", true);
        });
      })();

      (() => {
        // The thread list is loaded lazily into a Turbo Frame, so the show-more
        // button does not exist on initial page load. Wire it up both now (in
        // case the frame is already populated) and each time the frame loads.
        const wireShowMore = () => {
          const showMoreButton = document.querySelector("[data-console-thread-show-more]");
          if (!showMoreButton || showMoreButton.dataset.consoleThreadShowMoreWired === "true") return;

          const list = showMoreButton.closest(".console-thread-list");
          if (!list) return;

          const revealNextThreads = () => {
            const pageSize = Number.parseInt(showMoreButton.dataset.pageSize || "5", 10);
            const hiddenThreads = Array.from(list.querySelectorAll(".console-thread-link-hidden"));
            hiddenThreads.slice(0, Number.isFinite(pageSize) ? pageSize : 5).forEach((link) => {
              link.classList.remove("console-thread-link-hidden");
            });

            if (!list.querySelector(".console-thread-link-hidden")) {
              showMoreButton.hidden = true;
            }
          };

          if (!list.querySelector(".console-thread-link-hidden")) {
            showMoreButton.hidden = true;
          } else {
            showMoreButton.addEventListener("click", revealNextThreads);
          }
          showMoreButton.dataset.consoleThreadShowMoreWired = "true";
        };

        wireShowMore();
        document.addEventListener("turbo:frame-load", (event) => {
          if (event.target && event.target.id === "console_sidebar_threads") wireShowMore();
        });
      })();

      (() => {
        // The sidebar thread list is turbo-permanent, so it is not re-rendered
        // when navigating between threads. Re-derive the active highlight from
        // the page URL after every Turbo visit and after the frame's initial
        // lazy load, un-hiding an open thread that sits in the collapsed tail.
        const THREADS_PATH = "<%= console_threads_path %>";

        const syncSidebarActiveThreads = () => {
          const url = new URL(window.location.href);
          const openKeys = url.pathname.startsWith(THREADS_PATH)
            ? (url.searchParams.get("thread") || "").split(",").filter(Boolean)
            : [];

          document.querySelectorAll("[data-console-thread-link]").forEach((link) => {
            const key = new URL(link.href, window.location.origin).searchParams.get("thread");
            const paneIndex = openKeys.indexOf(key);
            const open = paneIndex !== -1;
            link.classList.toggle("console-thread-link-open", open);
            if (open) {
              // Dot for a single open thread; numbers once a second pane opens.
              if (openKeys.length > 1) {
                link.dataset.consolePaneIndex = String(paneIndex + 1);
              } else {
                delete link.dataset.consolePaneIndex;
              }
              link.classList.remove("console-thread-link-hidden");
            } else {
              delete link.dataset.consolePaneIndex;
            }
          });
        };

        document.addEventListener("turbo:load", syncSidebarActiveThreads);
        document.addEventListener("turbo:frame-load", (event) => {
          if (event.target && event.target.id === "console_sidebar_threads") syncSidebarActiveThreads();
        });
      })();

      (() => {
        // Sidebar thread clicks against the split-view grid. The thread param
        // carries up to PANEL_LIMIT comma-separated keys in grid order.
        //   - click or Cmd/Ctrl-click on an already-open thread closes it
        //   - Cmd/Ctrl-click on a closed thread adds it as a pane
        //   - plain click on a closed thread falls through to Turbo (replaces
        //     the selection with that single thread)
        // Capture phase so the close case wins over Turbo's own link handling;
        // delegated on document because the list arrives via a lazy frame.
        const THREADS_PATH = "<%= console_threads_path %>";
        const PANEL_LIMIT = <%= Console::ThreadsController::PANEL_LIMIT %>;

        document.addEventListener("click", (event) => {
          const link = event.target.closest("[data-console-thread-link]");
          if (!link) return;

          const key = new URL(link.href, window.location.origin).searchParams.get("thread");
          if (!key) return;

          const current = new URL(window.location.href);
          const openKeys = current.pathname.startsWith(THREADS_PATH)
            ? (current.searchParams.get("thread") || "").split(",").filter(Boolean)
            : [];
          const isOpen = openKeys.includes(key);
          const modified = event.metaKey || event.ctrlKey;

          let nextKeys;
          if (isOpen) {
            nextKeys = openKeys.filter((openKey) => openKey !== key);
          } else if (modified) {
            nextKeys = [...openKeys, key];
            // Keep the primary thread and the newest panes when over the limit.
            if (nextKeys.length > PANEL_LIMIT) {
              nextKeys = [nextKeys[0], ...nextKeys.slice(-(PANEL_LIMIT - 1))];
            }
          } else {
            return;
          }

          event.preventDefault();
          event.stopPropagation();

          const next = new URL(THREADS_PATH, window.location.origin);
          if (nextKeys.length) {
            next.searchParams.set("thread", nextKeys.join(","));
          } else {
            // Closing the last open thread lands on the empty state instead of
            // bouncing straight back via the auto-select redirect.
            next.searchParams.set("new", "1");
          }

          // Turbo visit keeps the turbo-permanent sidebar list mounted; a
          // plain location.assign would full-load and repaint it.
          if (window.Turbo) {
            window.Turbo.visit(next.toString());
          } else {
            window.location.assign(next.toString());
          }
        }, true);
      })();
    </script>
  </body>
</html>
