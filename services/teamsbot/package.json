{
  "name": "teamsbot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot --watch src/server.ts",
    "start": "bun src/server.ts",
    "simulate": "bun dev/simulate.ts",
    "test": "bun test test/*.test.ts",
    "check:types": "bun tsgo --project tsconfig.json --noEmit",
    "typecheck": "bun tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@centaur/harness-events": "workspace:*",
    "@centaur/rendering": "workspace:*",
    "@chat-adapter/state-pg": "^4.31.0",
    "@chat-adapter/teams": "^4.31.0",
    "chat": "^4.31.0",
    "dotenv": "^17.3.1",
    "express": "5.2.1",
    "pg": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/express": "5.0.6",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.15.5",
    "@typescript/native-preview": "^7.0.0-dev.20260512.1",
    "typescript": "^6.0.3"
  }
}
