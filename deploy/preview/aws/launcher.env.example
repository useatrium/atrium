# Required in production. Generate with:
#   openssl rand -hex 32
PREVIEW_LAUNCHER_TOKEN=

# AWS credentials should be supplied by the launcher host environment.
AWS_PROFILE=atrium-preview
AWS_REGION=us-east-1

PREVIEW_LAUNCHER_HOST=127.0.0.1
PREVIEW_LAUNCHER_PORT=8787
PREVIEW_LAUNCHER_DB=deploy/preview/aws/.state/launcher.sqlite3
PREVIEW_LAUNCHER_CLEANUP_INTERVAL_SECONDS=300
