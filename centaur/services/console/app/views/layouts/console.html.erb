<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= content_for(:title) || "Centaur Console" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%# Tailwind is compiled by the standalone binary into app/assets/builds/tailwind.css.
        See config/tailwind.config.js for the centaur/ink palette and radii overrides. %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      ::selection { background: #28c26a; color: #050506; }
      .glow { filter: drop-shadow(0 0 14px rgba(40,194,106,0.45)); }
      *::-webkit-scrollbar { width: 10px; height: 10px; }
      *::-webkit-scrollbar-track { background: #0b0b0d; }
      *::-webkit-scrollbar-thumb { background: #33333a; border-radius: 1px; }
      *::-webkit-scrollbar-thumb:hover { background: #28c26a; }
    </style>
  </head>

  <body class="h-full bg-ink-900 text-zinc-300 font-mono antialiased">
    <div class="min-h-full">
      <header class="border-b border-ink-600 bg-ink-850/80 backdrop-blur sticky top-0 z-10">
        <div class="mx-auto max-w-7xl px-6">
          <div class="flex items-center justify-between h-16">
            <a href="<%= root_path %>" class="group flex items-center" aria-label="Centaur Console">
              <%= image_tag "centaur-lockup-white.svg", alt: "Centaur", class: "h-7 w-auto glow", width: 497, height: 127 %>
            </a>
            <div class="flex items-center gap-4 text-sm">
              <nav class="flex items-center gap-1">
                <% nav = [
                  ["principals", console_principals_path],
                  ["roles", console_roles_path],
                  ["secrets", console_secrets_path],
                  ["credentials", console_credentials_path],
                  ["oauth apps", console_oauth_apps_path]
                ] %>
                <% nav << ["users", console_users_path] if current_user&.admin? %>
                <% nav << ["ETLs", console_etls_path] %>
                <% nav.each do |name, path| %>
                  <% active = request.path == path || (name == "principals" && request.path.start_with?("/console/principals")) || (name == "roles" && request.path.start_with?("/console/roles")) || (name == "ETLs" && request.path.start_with?("/console/etls")) %>
                  <a href="<%= path %>"
                     class="px-4 py-2 transition-colors <%= active ? "text-centaur-400" : "text-zinc-400 hover:text-zinc-100" %>">
                    <%= name == "ETLs" ? name : name.capitalize %>
                  </a>
                <% end %>
              </nav>

              <% if current_user %>
                <div class="flex items-center gap-3 border-l border-ink-600 pl-4">
                  <span class="text-zinc-500" title="<%= current_user.email %>"><%= current_user.email %></span>
                  <%= button_to "Sign out", logout_path, method: :delete,
                        class: "cursor-pointer rounded border border-ink-600 px-3 py-1.5 text-zinc-400 transition-colors hover:border-centaur-500/40 hover:text-centaur-300" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-6 py-10">
        <% if flash[:notice] %>
          <div class="mb-6 rounded border border-ink-600 bg-ink-850/60 px-4 py-3 text-sm text-zinc-400"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert] %>
          <div class="alert-error"><%= flash[:alert] %></div>
        <% end %>
        <%= yield %>
      </main>

    </div>
  </body>
</html>
