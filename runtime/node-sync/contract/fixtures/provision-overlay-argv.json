{
  "_comment": "manifest_writer + private_repo_hydrate: the EXACT argv centaur's init-container builders emit for the contract test inputs (asserted == emitted by centaur's contract tests; parsed by the daemon's in-bin tests). parser_coverage: not emitted — spans the rest of the declared flag inventory so declared ⊆ accepted stays pinned.",
  "manifest_writer": [
    "--manifest-only",
    "--session", "sess-1",
    "--overlays-root", "/var/lib/centaur/overlays",
    "--merged-root", "/run/centaur/merged",
    "--agent-uid", "1001",
    "--merged-path", "/run/centaur/merged/sess-1/agent",
    "--context-source", "/var/lib/centaur/atrium/sess-1",
    "--atrium-session", "slack:C1:1.2",
    "--flat-home",
    "--harness", "codex",
    "--harness-thread-id", "thread-1",
    "--harness-home", "/home/agent/.codex",
    "--repo", "/cache/github.com/acme/widget",
    "--repos-json", "[]"
  ],
  "private_repo_hydrate": [
    "--hydrate-private-repos",
    "--repos-json", "[]",
    "--repo-cache-root", "/cache",
    "--https-proxy", "http://iron-proxy:8080",
    "--git-ca-info", "/etc/centaur/ca/proxy-ca.crt"
  ],
  "parser_coverage": [
    "--manifest-only",
    "--replace",
    "--session", "sess-1",
    "--overlays-root", "/var/lib/centaur/overlays",
    "--merged-root", "/run/centaur/merged",
    "--lower", "/var/lib/centaur/overlay-lower/sess-1",
    "--generic-home-lower", "/var/lib/centaur/overlays/.warm-home-lower/sess-1"
  ]
}
