# Reducto API key for document parsing/extraction
REDUCTO_API_KEY=

# Reducto job timeouts (seconds)
PARSE_TIMEOUT_S=300
EXTRACT_TIMEOUT_S=300

# Reducto extract optimization (true/false)
EXTRACT_OPTIMIZE_FOR_LATENCY=true

# Browser-Use cloud API key for DocSend scraping
BROWSER_USE_API_KEY=

# Default DocSend email used for email-gated links (optional)
DOCSEND_EMAIL=

# Default Google account used for Drive sources (optional)
GOOGLE_ACCOUNT=your-service-account@example.com

# Browser-Use proxy country code (e.g. "us")
BROWSER_USE_PROXY_COUNTRY=

# Browser-Use persistent profile ID
BROWSER_USE_PROFILE_ID=

# DocSend debug directory (save screenshots/HTML for debugging)
DOCSEND_DEBUG_DIR=

# Telemetry / logging
LOG_LEVEL=INFO
LOG_FORMAT=json
RUN_ID=
STREAM_TEE=true
STREAM_DIR=logs/parchiver
STDOUT_LOG=
STDERR_LOG=
