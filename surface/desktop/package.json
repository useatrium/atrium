{
  "name": "@atrium/desktop",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "version": "0.1.0",
  "description": "Atrium desktop app — Electron shell around @atrium/web (bundle-local + token auth)",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/main/*.test.ts",
    "e2e": "playwright test",
    "prepackage": "pnpm --filter @atrium/web build && electron-vite build",
    "package:mac": "pnpm run prepackage && electron-builder --mac --config electron-builder.yml"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "^25.9.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
