<% content_for :title, "Credentials · Centaur Console" %>

<div class="mb-8 flex items-start justify-between gap-4">
  <div>
    <h1 class="page-title">Managed Credentials</h1>
    <p class="page-subtitle"><%= pluralize(@credentials.size, "broker credential") %>. Token material is never shown.</p>
  </div>
  <a href="<%= new_console_broker_credential_path %>" class="btn-primary">+ Add Credential</a>
</div>

<% if @credentials.empty? %>
  <p class="empty-state">No managed credentials.</p>
<% else %>
  <div class="console-panel">
    <table class="console-table">
      <thead class="console-table-head">
        <tr>
          <th class="console-th">ID</th>
          <th class="console-th">Name</th>
          <th class="console-th">Status</th>
          <th class="console-th">Last Refresh</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink-700">
        <% @credentials.each do |c| %>
          <tr class="console-row-hover">
            <td class="console-td-nowrap">
              <% if c.foreign_id.present? %>
                <%= link_to truncate_middle(c.foreign_id), console_credential_path(c.oid), class: "console-link", title: c.foreign_id %>
                <%= id_meta_line(c.namespace, oid: c.oid) %>
              <% else %>
                <%= link_to c.oid, console_credential_path(c.oid), class: "console-link" %>
                <%= id_meta_line(c.namespace) %>
              <% end %>
            </td>
            <td class="console-td-nowrap text-zinc-100">
              <% if c.name.presence %>
                <span title="<%= c.name %>"><%= truncate_middle(c.name) %></span>
              <% else %>
                <span class="text-zinc-600">unnamed</span>
              <% end %>
              <% if c.oauth_app %>
                <span class="ml-1 text-xs text-zinc-500">(via <%= c.oauth_app.provider.capitalize %> OAuth)</span>
              <% end %>
            </td>
            <td class="console-td-nowrap">
              <span class="rounded px-2 py-0.5 text-xs ring-1 <%= credential_status_classes(c.status) %>"><%= c.status %></span>
              <% if c.status == "dead" && c.dead_reason.present? %>
                <span class="ml-1 text-xs text-zinc-500"><%= c.dead_reason %></span>
              <% end %>
            </td>
            <td class="console-td-nowrap text-zinc-400"><%= local_time(c.last_refresh, relative: true) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
