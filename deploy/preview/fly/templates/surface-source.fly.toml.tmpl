# Template for building Atrium Surface from a checked-out Atrium commit.
#
# previewctl renders this file outside the target worktree, then runs:
# fly deploy <worktree> --dockerfile <worktree>/surface/deploy/Dockerfile.server

app = "{{FLY_APP_NAME}}"
primary_region = "{{FLY_REGION}}"

[env]
  HOST = "127.0.0.1"
  PORT = "3001"
  APPS_HOST = "127.0.0.1"
  APPS_PORT = "3002"
  AUTH_OPEN = "1"
  AUTH_DEV_CODES = "1"
  EMAIL_MODE = "log"
  LOG_LEVEL = "info"
  ARTIFACT_GC_ENABLED = "1"
  CENTAUR_HARNESS = "codex"
  ATRIUM_RATE_LIMIT = "0"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = false
  auto_start_machines = true
  min_machines_running = 1

  [http_service.concurrency]
    type = "requests"
    soft_limit = 50
    hard_limit = 100

[[vm]]
  cpu_kind = "shared"
  cpus = 1
  memory_mb = 1024
