# Copy to .env and edit before running:
#   cp surface/deploy/.env.example surface/deploy/.env
#
# Generate secrets:
#   openssl rand -base64 32
#   openssl rand -hex 32

# Database
DB_NAME=atrium
DB_USER=atrium
DB_PASSWORD=change-me-with-openssl-rand-hex-32
DB_HOST_PORT=5433

# Voice calls (optional). Leave empty to disable — the server returns
# calls_unconfigured and the `livekit` compose profile stays off. Enable with
# `docker compose --profile livekit up` and generate keys via:
#   docker run --rm livekit/livekit-server generate-keys
LIVEKIT_URL=
LIVEKIT_TURN_DOMAIN=turn.example.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Where LiveKit POSTs call-reaping webhooks. Normally leave empty: redeploy.sh
# derives it (loopback, or 10.42.0.1 under the tunnel override) to match where
# the server is published. Set only to override a bespoke topology/port.
LIVEKIT_WEBHOOK_URL=

# Server
SERVER_HOST_PORT=3001
SESSION_SECRET=change-me-with-openssl-rand-base64-32
LOG_LEVEL=info
PUSH_REDACT=1

# MinIO / S3-compatible file storage
MINIO_ACCESS_KEY=atrium
MINIO_PASSWORD=change-me-with-openssl-rand-hex-32
MINIO_HOST_PORT=9000
MINIO_API_CORS_ALLOW_ORIGIN=*
S3_BUCKET=atrium-files

# IMPORTANT:
# Presigned upload/download URLs embed S3_ENDPOINT exactly as configured here.
# This URL must be reachable from the phone, not just from Docker.
# Server byte I/O uses S3_INTERNAL_ENDPOINT; prod compose defaults it to http://minio:9000.
# Tailnet example: http://100.x.y.z:9000 or http://macbook.tailnet-name.ts.net:9000
# Scenario B options: https://minio.example.com or a Caddy path proxy you expose deliberately.
S3_ENDPOINT=http://100.x.y.z:9000
# S3_INTERNAL_ENDPOINT=http://minio:9000

# Centaur agent control plane.
# Leave these blank/default for chat-only deployments; the server still boots.
CENTAUR_BASE_URL=http://127.0.0.1:18000
CENTAUR_API_KEY=
# Dedicated key for the artifact serve route to fetch bytes from Centaur.
# Must match Centaur's ARTIFACT_CAPTURE_API_KEY (centaur-infra-env secret).
ARTIFACT_CAPTURE_API_KEY=
CENTAUR_HARNESS=codex

# Per-user GitHub connections through Centaur iron-control.
# Leave blank to keep GitHub connection writes disabled.
IRON_CONTROL_BASE_URL=
IRON_CONTROL_API_KEY=
IRON_CONTROL_NAMESPACE=default
# GitHub App user OAuth. Enables the primary "Connect GitHub user" button.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_REDIRECT_URL=
# GitHub App installation-token mode. Lets Surface create the iron-control
# broker credential from an installation id. Encode newlines as \n if keeping
# the private key on one line in .env.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_ID=
# Optional: lets Surface seed the github-default public-read fallback role.
GITHUB_PUBLIC_READ_TOKEN=

# Caddy
# Tailnet: use :80 for plain HTTP behind Tailscale.
# Internet-facing: use a real DNS name for Caddy auto-TLS.
SITE_ADDRESS=localhost
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443

# ============================================================================
# Host port binding
# ============================================================================
# Postgres binds to loopback only — admin access via the host or an SSH
# tunnel. Override only if you truly need remote DB access.
DB_BIND_HOST=127.0.0.1
# Server + MinIO bind address. Safe default: loopback only. For tailnet-only
# access you may set BIND_HOST=0.0.0.0 after confirming your host firewall only
# exposes these ports on the tailnet. For internet-facing deployments, keep
# BIND_HOST=127.0.0.1 and put Caddy/TLS in front.
BIND_HOST=127.0.0.1

# ---- Auth (optional) ----
# Open handle login is for local demos and private tailnets. Set AUTH_OPEN=1
# only when anyone who can reach the server is allowed to create an account.
# Internet-facing deployments should keep this closed and configure email or
# OAuth login.
AUTH_OPEN=0
# Email-code login delivery. EMAIL_MODE=log (default) only writes codes to the
# server log. For real email set:
#   EMAIL_MODE=resend
#   RESEND_API_KEY=re_...           (https://resend.com → API keys)
#   EMAIL_FROM=Atrium <login@your-verified-domain>
# (Resend requires verifying the sending domain first.)
EMAIL_MODE=log
# RESEND_API_KEY=
# EMAIL_FROM=
# ---- Google OAuth (optional; routes 404 until all three are set) ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URL=https://your-host/auth/oauth/google/callback
