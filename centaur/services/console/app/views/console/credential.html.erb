<% title = @credential.name.presence || @credential.foreign_id.presence || @credential.oid %>
<% content_for :title, "#{title} · Centaur Console" %>

<div class="mb-8">
  <a href="<%= console_credentials_path %>" class="back-link">← back to credentials</a>
  <div class="mt-2 flex flex-wrap items-center gap-3">
    <h1 class="page-title"><%= title %></h1>
    <span class="rounded px-2 py-0.5 text-xs ring-1 <%= credential_status_classes(@credential.status) %>"><%= @credential.status %></span>
    <div class="ml-auto flex items-center gap-2">
      <a href="<%= edit_console_broker_credential_path(@credential.oid) %>" class="btn-secondary">Edit</a>
      <%= button_to "Delete", console_broker_credential_path(@credential.oid), method: :delete,
            class: "cursor-pointer rounded border border-red-500/40 px-3 py-1.5 text-sm text-red-300 transition-colors hover:border-red-500/60 hover:bg-red-500/10",
            data: { turbo_confirm: "Delete this credential? This cannot be undone." } %>
    </div>
  </div>
  <div class="mt-2 flex flex-wrap items-center gap-2 text-sm">
    <span class="text-centaur-400 glow"><%= @credential.oid %></span>
    <span class="text-zinc-600">·</span>
    <span class="rounded bg-ink-700 px-2 py-0.5 text-xs text-zinc-400"><%= @credential.namespace %></span>
    <% if @credential.foreign_id.present? %>
      <span class="text-zinc-600">·</span>
      <span class="text-zinc-400">foreign_id: <span class="break-all text-zinc-200"><%= @credential.foreign_id %></span></span>
    <% end %>
  </div>
  <% if @credential.description.present? %>
    <p class="mt-3 max-w-2xl text-sm text-zinc-500"><%= @credential.description %></p>
  <% end %>
  <% if @credential.labels.present? %>
    <div class="mt-3 flex flex-wrap gap-1">
      <% @credential.labels.each do |k, v| %>
        <span class="label-chip"><%= k %>=<%= v %></span>
      <% end %>
    </div>
  <% end %>
</div>

<%
  # A labeled definition section. Each row is [label, value_html]; nil values
  # render an em-dash placeholder.
  def_section = ->(heading, rows) do
    content_tag(:section, class: "mb-8") do
      safe_join([
        content_tag(:h2, heading, class: "mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500"),
        content_tag(:dl, class: "console-panel divide-y divide-ink-700") do
          safe_join(rows.map do |label, value|
            content_tag(:div, class: "flex flex-col gap-1 px-5 py-3 sm:flex-row sm:gap-4") do
              content_tag(:dt, label, class: "w-48 shrink-0 text-xs uppercase tracking-wider text-zinc-500") +
                content_tag(:dd, value.presence || tag.span("—", class: "text-zinc-600"), class: "whitespace-pre-line break-all font-mono text-xs text-zinc-200")
            end
          end)
        end
      ])
    end
  end
%>

<%= def_section.call("Refresh", [
  [ "Last refresh", local_time(@credential.last_refresh, relative: true) ],
  [ "Expires", local_time(@credential.expires_at) ],
  [ "Next attempt", local_time(@credential.next_attempt_at) ],
  [ "Failure count", @credential.failure_count.to_s ],
  ([ "Dead reason", @credential.dead_reason ] if @credential.dead?)
].compact) %>

<%= def_section.call("Token Client", [
  [ "Grant", @credential.grant ],
  ([ "Client ID", @credential.effective_client_id ] if @credential.effective_client_id.present?),
  [ "Token endpoint", @credential.token_endpoint ],
  [ "Scopes", Array(@credential.scopes).join("\n") ],
  ([ "Username", "[redacted]" ] if @credential.grant == "password" && @credential.username.present?),
  ([ "Password", "[redacted]" ] if @credential.grant == "password" && @credential.password.present?),
  ([ "Username", "[redacted]" ] if @credential.grant == "preqin" && @credential.username.present?),
  ([ "API key", "[redacted]" ] if @credential.grant == "preqin" && @credential.api_key.present?),
  ([ "Token endpoint headers", Array(@credential.token_endpoint_headers&.keys).map { |k| "#{k}: [redacted]" }.join("\n") ] if @credential.token_endpoint_headers.present?)
].compact) %>

<%= def_section.call("Refresh Policy", [
  [ "Early refresh fraction", @credential.early_refresh_fraction.to_s ],
  [ "Early refresh slack", "#{@credential.early_refresh_slack_seconds}s" ],
  [ "Max refresh interval", "#{@credential.max_refresh_interval_seconds}s" ],
  [ "Refresh timeout", "#{@credential.refresh_timeout_seconds}s" ]
]) %>

<% if @credential.oauth_app %>
  <%= def_section.call("Provider Identity", [
    [ "OAuth app", link_to(@credential.oauth_app.slug, console_oauth_app_path(@credential.oauth_app.oid), class: "console-link") ],
    [ "Provider", @credential.oauth_app.provider ],
    [ "Provider email", @credential.provider_email ],
    [ "Provider subject", @credential.provider_subject ],
    [ "End-user key", @credential.external_user_key ]
  ]) %>
  <p class="-mt-6 mb-8 text-xs text-zinc-600">Client id and secret are inherited from the OAuth app; rotating the app's secret applies here.</p>
<% end %>

<% if @wrapping_secret %>
  <%= def_section.call("Grantable As", [
    [ "Static secret", link_to(@wrapping_secret.name.presence || @wrapping_secret.foreign_id.presence || @wrapping_secret.oid, console_secret_path("static", @wrapping_secret.oid), class: "console-link") ]
  ]) %>
  <p class="-mt-6 mb-8 text-xs text-zinc-600">Grant this credential to a principal by granting the static secret above; it injects the live token into matching requests.</p>
<% end %>

<%= def_section.call("Metadata", [
  [ "Created", local_time(@credential.created_at) ],
  [ "Updated", local_time(@credential.updated_at) ]
]) %>

<p class="text-xs text-zinc-600">Token material (access token, refresh token, client secret) is never shown.</p>
