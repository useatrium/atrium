{
  "name": "@atrium/mcp",
  "version": "0.1.0",
  "description": "Atrium MCP server — exposes addressable entries as resources (atrium://entry/<handle>).",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gbasin/atrium.git",
    "directory": "surface/mcp"
  },
  "bugs": {
    "url": "https://github.com/gbasin/atrium/issues"
  },
  "type": "module",
  "bin": {
    "atrium-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
