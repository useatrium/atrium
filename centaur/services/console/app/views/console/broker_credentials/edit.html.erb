<% title = @credential.name.presence || @credential.foreign_id.presence || @credential.oid %>
<% content_for :title, "Edit #{title} · Centaur Console" %>

<div class="mb-8">
  <a href="<%= console_credential_path(@credential.oid) %>" class="back-link">← back to credential</a>
  <div class="mt-2 flex flex-wrap items-center gap-3">
    <h1 class="page-title">Edit <%= title %></h1>
    <span class="resource-badge">Broker</span>
  </div>
</div>

<%= render "errors", credential: @credential %>
<%= render "form", credential: @credential %>
