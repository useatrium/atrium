set dotenv-load := true

namespace := env_var_or_default("CENTAUR_NAMESPACE", "centaur")
release := env_var_or_default("CENTAUR_RELEASE", "centaur")
source := env_var_or_default("CENTAUR_IMAGE_SOURCE", "local")
chart := "contrib/chart"
dev_values := "contrib/chart/values.dev.yaml"
# Command used to import images into k3s's containerd. Override for rootless or
# remote setups, e.g. CENTAUR_K3S_CTR="k3s ctr" or "ssh host sudo k3s ctr".
k3s_ctr := env_var_or_default("CENTAUR_K3S_CTR", "sudo k3s ctr")
# Local image registry `just up k3s` pushes to. Images are pushed under the
# `library/` namespace so k3s resolves the chart's bare `:latest` tags through a
# docker.io registry mirror — configure that on the node with:
#   /etc/rancher/k3s/registries.yaml
#     mirrors:
#       docker.io:
#         endpoint: ["http://localhost:5000"]
registry := env_var_or_default("CENTAUR_LOCAL_REGISTRY", "localhost:5000")
kind_cluster := env_var_or_default("CENTAUR_KIND_CLUSTER", "centaur")
agent_dockerfile := env_var_or_default("CENTAUR_AGENT_DOCKERFILE", "services/sandbox/Dockerfile")
agent_build_target := env_var_or_default("CENTAUR_AGENT_BUILD_TARGET", "sandbox")
agent_image := env_var_or_default("CENTAUR_AGENT_IMAGE", "centaur-agent:latest")
rust_build_profile := env_var_or_default("RUST_BUILD_PROFILE", "debug")
git_sha := `git rev-parse HEAD`
dirty_suffix := `if test -n "$(git status --porcelain)"; then printf %s -dirty; fi`
image_revision := git_sha + dirty_suffix

default:
    just --list

build:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ "${JUST_BUILD_SEQUENTIAL:-0}" =~ ^(1|true|yes)$ ]]; then
      just _build-all-sequential
    else
      pids=()
      for recipe in _build-api-rs _build-iron-proxy _build-slackbotv2 _build-discordbot _build-teamsbot _build-agent _build-node-sync _build-console; do
        just image_revision="{{image_revision}}" "$recipe" &
        pids+=("$!")
      done
      status=0
      for pid in "${pids[@]}"; do
        wait "$pid" || status=1
      done
      exit "$status"
    fi

_build-all-sequential:
    just image_revision="{{image_revision}}" _build-api-rs
    just image_revision="{{image_revision}}" _build-iron-proxy
    just image_revision="{{image_revision}}" _build-slackbotv2
    just image_revision="{{image_revision}}" _build-discordbot
    just image_revision="{{image_revision}}" _build-teamsbot
    just image_revision="{{image_revision}}" _build-agent
    just image_revision="{{image_revision}}" _build-node-sync
    just image_revision="{{image_revision}}" _build-console

build-one service:
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{service}}" in
      api-rs) just _build-api-rs ;;
      iron-proxy) just _build-iron-proxy ;;
      slackbotv2) just _build-slackbotv2 ;;
      discordbot) just _build-discordbot ;;
      teamsbot) just _build-teamsbot ;;
      agent|sandbox) just _build-agent ;;
      node-sync) just _build-node-sync ;;
      console) just _build-console ;;
      *) echo "unknown service: {{service}}" >&2; exit 2 ;;
    esac

_build-api-rs:
    docker build --label "org.opencontainers.image.revision={{image_revision}}" --build-arg "RUST_BUILD_PROFILE={{rust_build_profile}}" -t centaur-api-rs:latest -f services/api-rs/Dockerfile .

_build-iron-proxy:
    docker build --label "org.opencontainers.image.revision={{image_revision}}" -t centaur-iron-proxy:latest -f services/iron-proxy/Dockerfile .

_build-slackbotv2:
    docker build --label "org.opencontainers.image.revision={{image_revision}}" -t centaur-slackbotv2:latest -f services/slackbotv2/Dockerfile .

_build-discordbot:
    docker build --label "org.opencontainers.image.revision={{image_revision}}" -t centaur-discordbot:latest -f services/discordbot/Dockerfile .

_build-teamsbot:
    docker build --label "org.opencontainers.image.revision={{image_revision}}" -t centaur-teamsbot:latest -f services/teamsbot/Dockerfile .

_build-agent:
    docker build --label "org.opencontainers.image.revision={{image_revision}}" --build-arg "RUST_BUILD_PROFILE={{rust_build_profile}}" --target "{{agent_build_target}}" -t "{{agent_image}}" -f "{{agent_dockerfile}}" .

# The node-sync image builds from services/api-rs as its context (not the repo
# root), so services/api-rs/.dockerignore controls the transferred files.
_build-node-sync:
    cd services/api-rs && docker build --label "org.opencontainers.image.revision={{image_revision}}" --build-arg "RUST_BUILD_PROFILE={{rust_build_profile}}" -f crates/centaur-node-sync/Dockerfile -t centaur-node-sync:latest .

# The console builds from its own subdirectory context (services/console), unlike
# the other services which build from the repo root.
_build-console:
    docker build --label "org.opencontainers.image.revision={{image_revision}}" -t centaur-console:latest -f services/console/Dockerfile services/console

build-changed:
    #!/usr/bin/env bash
    set -euo pipefail
    head_sha="{{git_sha}}"
    dirty_suffix="{{dirty_suffix}}"
    entries=(
      "api-rs|centaur-api-rs|_build-api-rs"
      "iron-proxy|centaur-iron-proxy|_build-iron-proxy"
      "slackbotv2|centaur-slackbotv2|_build-slackbotv2"
      "discordbot|centaur-discordbot|_build-discordbot"
      "teamsbot|centaur-teamsbot|_build-teamsbot"
      "agent|centaur-agent|_build-agent"
      "node-sync|centaur-node-sync|_build-node-sync"
      "console|centaur-console|_build-console"
    )
    for entry in "${entries[@]}"; do
      IFS='|' read -r service image recipe <<<"$entry"
      label="$(docker image inspect "${image}:latest" --format '{{ "{{" }}index .Config.Labels "org.opencontainers.image.revision"{{ "}}" }}' 2>/dev/null || true)"
      if [[ -z "$dirty_suffix" && "$label" == "$head_sha" ]]; then
        echo "skip ${service}: ${image}:latest already built from ${head_sha}"
        continue
      fi
      if [[ -n "$dirty_suffix" ]]; then
        echo "build ${service}: working tree is dirty; stamping ${head_sha}${dirty_suffix}"
      elif [[ -z "$label" ]]; then
        echo "build ${service}: ${image}:latest missing revision label"
      else
        echo "build ${service}: image revision ${label} != ${head_sha}"
      fi
      just image_revision="${head_sha}${dirty_suffix}" "$recipe"
    done

# Push locally-built images to the local registry under library/ so k3s pulls
# them via its docker.io mirror. Used by `just up k3s`. Only changed layers are
# pushed, so this is much faster than `_import-k3s` on repeat runs.
_push-registry:
    #!/usr/bin/env bash
    set -euo pipefail
    for img in centaur-api-rs centaur-iron-proxy centaur-slackbotv2 centaur-discordbot centaur-teamsbot centaur-agent centaur-node-sync centaur-console; do
      target="{{registry}}/library/${img}:latest"
      echo "pushing ${img}:latest -> ${target}..."
      docker tag "${img}:latest" "${target}"
      docker push "${target}"
    done

_ensure-registry:
    #!/usr/bin/env bash
    set -euo pipefail
    name=kind-registry
    if ! docker container inspect "$name" >/dev/null 2>&1; then
      docker run -d --restart=always -p "127.0.0.1:5000:5000" --name "$name" registry:3 >/dev/null
    elif [[ -z "$(docker ps --filter "name=^/${name}$" --filter status=running -q)" ]]; then
      docker start "$name" >/dev/null
    fi
    if docker network inspect kind >/dev/null 2>&1; then
      docker network connect kind "$name" 2>/dev/null || true
    else
      echo "kind docker network not found; create/recreate the kind cluster with infra/kind-cluster.yaml before deploying via registry" >&2
    fi

# Legacy: import locally-built images straight into k3s's containerd (no registry
# needed). Slower than `_push-registry`; kept as a fallback. Run manually with
# `just _import-k3s`.
_import-k3s:
    #!/usr/bin/env bash
    set -euo pipefail
    for img in centaur-api-rs centaur-iron-proxy centaur-slackbotv2 centaur-discordbot centaur-teamsbot centaur-agent centaur-node-sync centaur-console; do
      echo "importing ${img}:latest into k3s containerd..."
      docker save "${img}:latest" | {{k3s_ctr}} images import -
    done

_import-kind:
    #!/usr/bin/env bash
    set -euo pipefail
    for img in centaur-api-rs centaur-iron-proxy centaur-slackbotv2 centaur-discordbot centaur-teamsbot centaur-agent centaur-node-sync centaur-console; do
      echo "importing ${img}:latest into kind cluster {{kind_cluster}}..."
      kind load docker-image --name "{{kind_cluster}}" "${img}:latest"
    done

bootstrap-secrets *args:
    contrib/scripts/bootstrap-k8s-secrets.sh --namespace {{namespace}} {{args}}

deploy:
    #!/usr/bin/env bash
    set -euo pipefail
    helm dependency update {{chart}} >/dev/null
    extra_args=()
    case "{{source}}" in
      local) ;;
      kind)
        extra_args+=(
          --set apiRs.image.repository={{registry}}/library/centaur-api-rs
          --set ironProxy.image.repository={{registry}}/library/centaur-iron-proxy
          --set slackbotv2.image.repository={{registry}}/library/centaur-slackbotv2
          --set discordbot.image.repository={{registry}}/library/centaur-discordbot
          --set teamsbot.image.repository={{registry}}/library/centaur-teamsbot
          --set sandbox.image.repository={{registry}}/library/centaur-agent
          --set nodeSync.image.repository={{registry}}/library/centaur-node-sync
          --set console.image.repository={{registry}}/library/centaur-console
        )
        ;;
      ghcr)
        extra_args+=(
          --set apiRs.image.repository=ghcr.io/paradigmxyz/centaur/centaur-api-rs
          --set ironProxy.image.repository=ghcr.io/paradigmxyz/centaur/centaur-iron-proxy
          --set slackbotv2.image.repository=ghcr.io/paradigmxyz/centaur/centaur-slackbotv2
          --set discordbot.image.repository=ghcr.io/paradigmxyz/centaur/centaur-discordbot
          --set teamsbot.image.repository=ghcr.io/paradigmxyz/centaur/centaur-teamsbot
          --set sandbox.image.repository=ghcr.io/paradigmxyz/centaur/centaur-agent
          --set nodeSync.image.repository=ghcr.io/paradigmxyz/centaur/centaur-node-sync
          --set console.image.repository=ghcr.io/paradigmxyz/centaur/centaur-console
        )
        ;;
      *) echo "unknown source: {{source}} (expected local, kind, or ghcr)" >&2; exit 2 ;;
    esac
    if [[ -n "${OP_CONNECT_CREDENTIALS_FILE:-}" ]]; then
      extra_args+=(
        --set ironProxy.secretSource=onepassword-connect
        --set onepasswordConnect.connect.create=true
      )
    fi
    if [[ -n "${CODEX_AUTH_MODE:-}" ]]; then
      extra_args+=(
        --set sandbox.codexAuthMode=${CODEX_AUTH_MODE}
      )
    fi
    if [[ -n "${CLAUDE_CODE_AUTH_MODE:-}" ]]; then
      extra_args+=(
        --set sandbox.claudeCodeAuthMode=${CLAUDE_CODE_AUTH_MODE}
      )
    fi
    # Layer an optional local-only values file (e.g. Tailscale Funnel ingress) on
    # top of values.dev.yaml. Kept out of the shared dev values so teammates'
    # `just up` is unaffected. Appended after -f {{dev_values}} so it wins
    # (helm applies -f files left-to-right).
    if [[ -n "${CENTAUR_EXTRA_VALUES:-}" ]]; then
      extra_args+=(-f "${CENTAUR_EXTRA_VALUES}")
    fi
    helm upgrade --install {{release}} {{chart}} -n {{namespace}} --create-namespace -f {{dev_values}} ${extra_args[@]+"${extra_args[@]}"}

# Bring up the dev stack; pass `k3s` or `kind` to push local images to the local
# registry (CENTAUR_LOCAL_REGISTRY, default localhost:5000) before deploying.
up import="":
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ -n "{{import}}" && "{{import}}" != "k3s" && "{{import}}" != "kind" ]]; then
      echo "unknown argument: {{import}} (expected nothing, 'k3s', or 'kind')" >&2; exit 2
    fi
    just bootstrap-secrets
    case "{{source}}" in
      local)
        just build
        if [[ "{{import}}" == "k3s" ]]; then
          just _push-registry
        elif [[ "{{import}}" == "kind" ]]; then
          just _ensure-registry
          just _push-registry
        fi
        ;;
      ghcr) ;;
      *) echo "unknown source: {{source}} (expected local or ghcr)" >&2; exit 2 ;;
    esac
    deploy_source="{{source}}"
    if [[ "{{import}}" == "kind" ]]; then
      deploy_source=kind
    fi
    just source="${deploy_source}" deploy

debug-sandbox:
    #!/usr/bin/env bash
    set -euo pipefail
    ns="{{namespace}}"
    out_dir="${CENTAUR_DEBUG_SANDBOX_DIR:-/tmp}"
    echo "watching for asbx-* pods in namespace ${ns}; writing describe/logs to ${out_dir}"
    while true; do
      pod="$(kubectl get pods -n "$ns" --no-headers 2>/dev/null | awk '$1 ~ /^asbx-/ && $1 !~ /-proxy-/ {print $1; exit}')"
      if [[ -n "${pod:-}" ]]; then
        stamp="$(date +%Y%m%dT%H%M%S)"
        prefix="${out_dir}/${pod}-${stamp}"
        proxy_pod=""
        for _ in {1..50}; do
          proxy_pod="$(kubectl get pods -n "$ns" --no-headers 2>/dev/null | awk -v p="${pod}-proxy-" 'index($1, p) == 1 {print $1; exit}')"
          [[ -n "$proxy_pod" ]] && break
          sleep 0.1
        done
        echo "capturing ${pod} -> ${prefix}.{describe,agent.log,iron-proxy.log}"
        kubectl describe pod -n "$ns" "$pod" > "${prefix}.describe" 2>&1 || true
        if [[ -n "$proxy_pod" ]]; then
          kubectl describe pod -n "$ns" "$proxy_pod" > "${prefix}.iron-proxy.describe" 2>&1 || true
        fi
        pids=()
        kubectl logs -n "$ns" "$pod" -c agent --timestamps -f > "${prefix}.agent.log" 2>&1 &
        pids+=("$!")
        if [[ -n "$proxy_pod" ]]; then
          kubectl logs -n "$ns" "$proxy_pod" -c iron-proxy --timestamps -f > "${prefix}.iron-proxy.log" 2>&1 &
          pids+=("$!")
        else
          echo "matching iron-proxy pod was not found for ${pod}" > "${prefix}.iron-proxy.log"
        fi
        trap 'kill "${pids[@]}" 2>/dev/null || true' INT TERM EXIT
        wait "${pids[@]}" || true
        exit 0
      fi
      sleep 0.2
    done

down:
    kubectl delete namespace {{namespace}} --ignore-not-found --wait

reinstall:
    just down
    just up

status:
    kubectl get all -n {{namespace}}

logs component:
    kubectl logs -n {{namespace}} deploy/{{release}}-centaur-{{component}} --tail=200 -f

shell component:
    kubectl exec -it -n {{namespace}} deploy/{{release}}-centaur-{{component}} -- sh
