{
	email {$ACME_EMAIL}
	acme_dns cloudflare {env.CF_API_TOKEN}
	auto_https prefer_wildcard
}

# One wildcard cert (DNS-01) covers every preview, so no per-preview issuance.
*.__ATRIUM_PREVIEW_DOMAIN__ {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	respond "preview route not found" 404
}

# previewctl writes one file per preview into conf.d and reloads Caddy
# (docker exec ... caddy reload). Its fragment follows this shape:
#
# prev-<sha12>-<rand4hex>.__ATRIUM_PREVIEW_DOMAIN__ {
#     encode zstd gzip
#
#     # presigned S3 reads hit the public origin, so send them straight to minio
#     @minio path /atrium-prev-<...>/*
#     handle @minio {
#         reverse_proxy 127.0.0.1:<minio-port>
#     }
#
#     # everything else goes to the preview's own caddy, which serves the web SPA
#     # and proxies /api,/auth,/ws,/healthz to its server
#     handle {
#         reverse_proxy 127.0.0.1:<preview-caddy-port>
#     }
# }

import /etc/caddy/conf.d/*.caddy
