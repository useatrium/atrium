# syntax=docker/dockerfile:1.7
#
# Atrium's agent image. Selected via CENTAUR_AGENT_DOCKERFILE (see centaur/Justfile);
# upstream's services/sandbox/Dockerfile is left byte-for-byte alone so subtree pulls
# stay merge-clean.
#
# This is a copy of that file with payload Atrium provably does not use removed. It is
# NOT a `--target` of it: the fat payload lives in the `toolchain` stage and stages are
# additive, so a later stage cannot subtract. A separate file is the only way.
#
# Omitted vs upstream, with the evidence for each:
#   libclang-dev/llvm-18 (412M) — `bindgen` is in no Cargo.lock; aws-lc-sys 0.41 uses
#     prebuilt bindings (it needs cmake, which stays). Agents cannot pull a bindgen
#     crate either: crates.io is outside the egress allowlist (infra/values.local.yaml)
#     and the sandbox stage removes their sudo.
#   TeX Live + ghostscript + dvisvgm (434M) — zero consumers. md2docx.py is pure
#     python-docx. Only manim plausibly wanted TeX, and manim is gone too.
#   manim + libcairo2-dev/libpango1.0-dev (369M) — referenced only by upstream's
#     Dockerfile; never wired, never prompted. (Chrome's runtime cairo/pango libs are
#     a different, non-dev set and are still installed below.)
#   foundry (223M) — no .sol or foundry.toml in this repo. Upstream's need, not ours.
#   pi-coding-agent (151M) — no harness enum variant, no backend. Dead in the fork.
#   amp (117M) — harness set is codex + claudecode; entrypoint.sh's amp branch is
#     unreachable.
#   nushell (57M) — advertised only by upstream's SYSTEM_PROMPT.md, which never reaches
#     an Atrium agent (ATRIUM_BASE_PROMPT.md wins via CENTAUR_OVERLAY_DIR).
#   kache — Dockerfile-only, never wired at runtime. sccache is the real one and stays.
#   nightly toolchain (589M) — nothing here needs it: no rust-toolchain.toml, no
#     #![feature(...)], and CI checks formatting with *stable* rustfmt. Kept only by a
#     prompt line that contradicted CI; that line is fixed in ATRIUM_BASE_PROMPT.md.
#
# Deliberately kept: cmake/build-essential (aws-lc-sys), stable Rust + rustfmt + clippy,
# sccache (warm-lease cache), the docx/pptx/xlsx/PyMuPDF set (named in the live prompt),
# matplotlib/numpy/pandas/faster-whisper, agent-browser + Chrome (the baked `dogfood`
# skill declares Bash(agent-browser:*)), codex, claude-code, claude-agent-sdk, pnpm, bun.
#
# DRIFT: the final stage below must track upstream's. scripts/check-agent-dockerfile.sh
# fails CI if they diverge — do not edit the final stage here without editing it there.

FROM ubuntu:24.04 AS toolchain

ENV PYTHONDONTWRITEBYTECODE=1

# ── System packages (cached unless base image changes) ───────────────────────
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    git curl wget ca-certificates gnupg lsb-release sudo \
    build-essential pkg-config cmake ninja-build \
    ffmpeg file \
    libssl-dev protobuf-compiler \
    ripgrep fd-find jq tree tmux unzip xz-utils gettext-base vim \
    postgresql-client libpq-dev \
    python3 python3-pip python3-venv python3-dev \
    procps htop \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && rm -rf /usr/share/doc /usr/share/man /usr/share/info

# ── Python deps ──────────────────────────────────────────────────────────────
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    pip3 install --break-system-packages --no-compile \
    python-docx==1.2.0 lxml==6.0.2 docx-revisions==0.1.4 \
    matplotlib==3.10.8 numpy==2.4.4 pandas==3.0.2 \
    python-pptx==1.0.2 openpyxl==3.1.5 PyMuPDF==1.27.2 mammoth==1.12.0 \
    faster-whisper \
    asyncpg==0.30.0 \
    boto3>=1.40.0 \
    google-api-python-client>=2.100.0 \
    google-auth-httplib2>=0.2.0 \
    google-auth-oauthlib>=1.2.0 \
    feedparser>=6.0.0 \
    httplib2>=0.20.0 \
    httpx>=0.28.0 \
    opentelemetry-proto==1.42.1 \
    pysocks>=1.7.1 \
    rich>=13.0.0 \
    slack-sdk==3.39.0 \
    tomli-w==1.2.0 \
    && find /usr/local/lib/python3.12 /usr/lib/python3 -type d -name __pycache__ -prune -exec rm -rf '{}' +

# ── GitHub CLI + Node.js 24 (LTS) + Docker CLI (single layer, cached) ─────────────
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
      | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
      | tee /etc/apt/sources.list.d/docker.list > /dev/null \
    && apt-get update && apt-get install -y --no-install-recommends gh nodejs docker-ce-cli \
    && rm -rf /usr/share/doc /usr/share/man /usr/share/info

# ── Non-root agent user ─────────────────────────────────────────────────────
RUN useradd -m -s /bin/bash -u 1001 agent \
    && echo "agent ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/agent

ARG CLAUDE_CODE_VERSION=2.1.185
ARG CLAUDE_AGENT_SDK_VERSION=0.3.185
ARG CODEX_VERSION=0.139.0
ARG KUBECTL_VERSION=v1.34.2
ARG SCCACHE_VERSION=v0.8.2
# Bootstrap pnpm for agents working in JS monorepos. The exact baked version
# doesn't constrain repos: when a repo's `packageManager` field declares a
# different version, pnpm downloads and runs that one (v11 `pmOnFail=download`
# default; `manage-package-manager-versions` in v10) over the same registry
# egress a dependency install already needs.
ARG PNPM_VERSION=11.5.3

# ── kubectl ──────────────────────────────────────────────────────────────────
RUN set -eux; \
    kubectl_arch="$(case "$(dpkg --print-architecture)" in \
      amd64) echo amd64 ;; \
      arm64) echo arm64 ;; \
      *) echo unsupported-architecture >&2; exit 1 ;; \
    esac)"; \
    curl -fsSL \
      "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${kubectl_arch}/kubectl" \
      -o /usr/local/bin/kubectl; \
    chmod +x /usr/local/bin/kubectl; \
    kubectl version --client=true | grep -F "${KUBECTL_VERSION#v}"

# ── sccache (shared compiler cache; wired via RUSTC_WRAPPER at runtime) ───────
# Static musl build; the runtime entrypoint points SCCACHE_DIR at the node
# dep-cache mount so compile artifacts survive across sessions.
RUN set -eux; \
    sccache_arch="$(case "$(dpkg --print-architecture)" in \
      amd64) echo x86_64 ;; \
      arm64) echo aarch64 ;; \
      *) echo unsupported-architecture >&2; exit 1 ;; \
    esac)"; \
    curl -fsSL \
      "https://github.com/mozilla/sccache/releases/download/${SCCACHE_VERSION}/sccache-${SCCACHE_VERSION}-${sccache_arch}-unknown-linux-musl.tar.gz" \
      -o /tmp/sccache.tar.gz; \
    mkdir -p /tmp/sccache; \
    tar -xzf /tmp/sccache.tar.gz -C /tmp/sccache --strip-components=1; \
    install -m 0755 /tmp/sccache/sccache /usr/local/bin/sccache; \
    rm -rf /tmp/sccache /tmp/sccache.tar.gz; \
    sccache --version | grep -F "${SCCACHE_VERSION#v}"

# ── Global npm CLIs (root) ──────────────────────────────────────────────────
RUN --mount=type=cache,target=/root/.npm,sharing=locked \
    npm install -g --prefer-online --force \
      "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
      "@anthropic-ai/claude-agent-sdk@${CLAUDE_AGENT_SDK_VERSION}" \
      "@openai/codex@${CODEX_VERSION}" \
      "pnpm@${PNPM_VERSION}" \
      agent-browser@0.26.0 \
    && find /usr/lib/node_modules -type f \( -name '*.map' -o -name '*.tsbuildinfo' \) -delete \
    && claude --version | grep -F "${CLAUDE_CODE_VERSION}" \
    && codex --version | grep -F "${CODEX_VERSION}" \
    && pnpm --version | grep -F "${PNPM_VERSION}"

# ── agent-browser system deps (must run as root before USER agent) ───────────
# Chrome for Testing doesn't provide Linux ARM64 builds; fall back to system chromium
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    if [ "$(dpkg --print-architecture)" = "amd64" ]; then \
      apt-get update && apt-get install -y --no-install-recommends \
        libxcb-shm0 libx11-xcb1 libx11-6 libxcb1 libxext6 libxrandr2 \
        libxcomposite1 libxcursor1 libxdamage1 libxfixes3 libxi6 \
        libgtk-3-0t64 libpangocairo-1.0-0 libpango-1.0-0 libatk1.0-0t64 \
        libcairo-gobject2 libcairo2 libgdk-pixbuf-2.0-0 libxrender1 \
        libasound2t64 libfreetype6 libfontconfig1 libdbus-1-3 libnss3 \
        libnspr4 libatk-bridge2.0-0t64 libdrm2 libxkbcommon0 \
        libatspi2.0-0t64 libcups2t64 libxshmfence1 libgbm1 \
        fonts-noto-color-emoji fonts-noto-cjk fonts-freefont-ttf; \
    else \
      echo "Skipping browser install: Chrome for Testing does not publish Linux ARM64 builds"; \
    fi

RUN install -d -m 0775 -o agent -g agent \
      /opt/centaur \
      /opt/centaur/cargo \
      /opt/centaur/rustup \
      /opt/centaur/bun \
      /opt/centaur/local \
      /opt/centaur/local/bin \
      /opt/centaur/uv-tools

USER agent
WORKDIR /home/agent

ENV CARGO_HOME=/opt/centaur/cargo \
    RUSTUP_HOME=/opt/centaur/rustup \
    BUN_INSTALL=/opt/centaur/bun \
    UV_TOOL_DIR=/opt/centaur/uv-tools \
    UV_TOOL_BIN_DIR=/opt/centaur/local/bin \
    CENTAUR_TOOL_BIN_DIR=/opt/centaur/local/bin \
    CENTAUR_SKILL_DIRS=/opt/centaur/agents/skills \
    CENTAUR_HARNESS_CONFIG_DIR=/opt/centaur/harness \
    PATH="/opt/centaur/cargo/bin:/opt/centaur/local/bin:/opt/centaur/bun/bin:${PATH}"

ARG BUN_VERSION=bun-v1.3.13

# ── Agent-scoped toolchains ─────────────────────────────────────────────────
# Stable only, with rustfmt + clippy on it. Upstream defaults to nightly and installs
# stable `--profile minimal` (i.e. with no rustfmt/clippy at all); Atrium inverts that
# because CI checks formatting with stable rustfmt, so nightly-formatted code is CI-red.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
      | sh -s -- -y --profile minimal --default-toolchain stable --component rustfmt --component clippy \
    && rustc --version \
    && cargo --version \
    && rustfmt --version \
    && clippy-driver --version \
    && cargo fmt --version \
    && cargo clippy --version \
    && rm -rf "$RUSTUP_HOME/toolchains"/*/share/doc "$RUSTUP_HOME/toolchains"/*/share/man
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/opt/centaur/local/bin sh
RUN curl -fsSL https://bun.sh/install | bash -s "${BUN_VERSION}"

# ── agent-browser: download Chrome binary (runs as agent, deps already installed) ─
RUN if [ "$(dpkg --print-architecture)" = "amd64" ]; then \
      agent-browser install; \
    fi

# ── Agent skills + workspace setup (rarely changes) ─────────────────────────
RUN --mount=type=cache,target=/home/agent/.npm,uid=1001,gid=1001,sharing=locked \
    npx -y skills add vercel-labs/agent-browser
# Global git config must live OUTSIDE /home/agent so it survives the flat-~ overlay
# (which shadows the baked home). git reads $GIT_CONFIG_GLOBAL at runtime.
ENV GIT_CONFIG_GLOBAL=/opt/centaur/gitconfig
RUN mkdir -p ~/.codex ~/repos ~/workspace \
    && git config --global init.defaultBranch main \
    && git config --global push.autoSetupRemote true \
    && git config --global core.hooksPath /opt/centaur/git-hooks \
    && git config --global --add safe.directory '*' \
    && git config --global user.name "Centaur AI" \
    && git config --global user.email "ai@centaur.local" \
    && git config --global include.path /home/agent/context/.atrium-git-identity

# ==============================================================================
# Final thin stage: only frequently-changing local files below.
# Changing harness_session.py / SYSTEM_PROMPT.md / entrypoint.sh rebuilds only
# the COPY layers — the entire toolchain stage stays cached.
# ==============================================================================

FROM toolchain AS sandbox

USER root
RUN rm -f /etc/sudoers.d/agent
# BuildKit's COPY --link creates parent directories without an explicit mode,
# which can leave /etc/centaur without the execute bit for non-root users.
# Pre-create /etc/centaur as 0755 so the agent user can traverse into it at runtime.
# Keep /opt/centaur writable by agent for the relocated baked toolchain.
RUN install -d -m 0755 /etc/centaur \
    && install -d -m 0775 -o agent -g agent /opt/centaur
COPY --link centaur_sdk/ /opt/centaur/centaur_sdk/
COPY --link --chmod=0755 services/sandbox/git-hooks/ /opt/centaur/git-hooks/
COPY --link --chown=1001:1001 tools/ /opt/centaur/tools/
COPY --link --chmod=644 services/sandbox/codex-auth.json /etc/centaur/codex-auth.default.json
COPY --link --chmod=644 services/sandbox/claude-credentials.json /etc/centaur/claude-credentials.default.json
COPY --link --chmod=755 services/sandbox/md2docx.py /usr/local/bin/md2docx
COPY --link --chmod=755 services/workflow-python/workflow_host.py /usr/local/bin/workflow-host
COPY --link services/workflow-python/api/ /usr/local/bin/api/
COPY --link --chmod=755 services/sandbox/git-branch.sh /usr/local/bin/git-branch
COPY --link --chmod=755 services/sandbox/claude-sdk-bridge.mjs /usr/local/bin/claude-sdk-bridge
COPY --link --chmod=755 services/sandbox/install_tool_shims.py /usr/local/bin/install-tool-shims
COPY --link --chmod=755 services/sandbox/centaur_tool_host.py /usr/local/bin/centaur-tool-host
COPY --link --chmod=755 services/sandbox/repo_cache_sync.py /usr/local/bin/repo-cache-sync
COPY --link --chmod=755 services/sandbox/repo_cache_watch.py /usr/local/bin/repo-cache-watch
COPY --link --chmod=755 services/sandbox/entrypoint.sh /entrypoint.sh
COPY --link --chown=1001:1001 crates/harness-server/ /opt/centaur/harness-server-src/

USER agent
WORKDIR /home/agent

ARG RUST_BUILD_PROFILE=release
# Keep harness-server source as a real image input so crate changes invalidate
# the install layer. Do not COPY into /tmp; that can clobber /tmp's sticky bit.
RUN --mount=type=cache,target=/opt/centaur/cargo/registry,uid=1001,gid=1001,sharing=locked \
    --mount=type=cache,target=/opt/centaur/cargo/git,uid=1001,gid=1001,sharing=locked \
    --mount=type=cache,target=/home/agent/.cache/harness-server-target,uid=1001,gid=1001,sharing=locked \
    export CARGO_TARGET_DIR=/home/agent/.cache/harness-server-target; \
    case "$RUST_BUILD_PROFILE" in \
      release) cargo install --locked --path /opt/centaur/harness-server-src --root /opt/centaur/local ;; \
      debug|dev) cargo install --debug --locked --path /opt/centaur/harness-server-src --root /opt/centaur/local ;; \
      *) echo "unsupported RUST_BUILD_PROFILE=$RUST_BUILD_PROFILE" >&2; exit 2 ;; \
    esac

# No RUN instructions after these — all repo-local content at the very end.
COPY --link --chown=1001:1001 .agents/skills/ /opt/centaur/agents/skills/
# NOTE: harness/ and crates/harness-server/ are agent-image INPUTS — deploy's
# need_agent change-detection must include them (deploy/redeploy.sh), or edits
# here ship as stale retags under a new SHA.
COPY --link --chown=1001:1001 harness/ /opt/centaur/harness/
COPY --link --chown=1001:1001 workflows/ /opt/centaur/workflows/
COPY --link --chown=1001:1001 services/sandbox/SYSTEM_PROMPT.md /opt/centaur/AGENTS.md
# Atrium fork: bake the Atrium-native base prompt into the image. The chart's
# overlay.systemPrompt ConfigMap only reaches the api-rs pod — sandbox pods are
# created dynamically and never mount it. A pod-level CENTAUR_OVERLAY_DIR env
# still wins over this image default (external overlay-repo deployments work).
COPY --link --chown=1001:1001 services/sandbox/ATRIUM_BASE_PROMPT.md /opt/centaur-overlay/services/sandbox/BASE_PROMPT.md
ENV CENTAUR_OVERLAY_DIR=/opt/centaur-overlay

ENTRYPOINT ["/entrypoint.sh"]
# Default CMD uses Rust blocks mode; pass --mode=jsonrpc for raw App Server JSON-RPC.
CMD ["harness-server", "codex"]
