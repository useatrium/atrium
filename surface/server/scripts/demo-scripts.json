            "content": "def next_retry_delay(attempt: int) -> float:\n    \"\"\"Exponential backoff for OCR pool retries.\n\n    Capped so a stuck batch fails fast instead of holding a worker.\n    \"\"\"\n    return min(BASE_DELAY * 2 ** attempt, 30.0)\n\n\nasync def process_batch(batch: Batch) -> None:\n    for attempt in range(MAX_RETRIES):\n        try:\n            return await ocr_pool.submit(batch)\n        except PoolUnavailable:\n            delay = next_retry_delay(attempt)\n            log.warning(\"ocr_retry\", attempt=attempt, delay=delay)\n            time.sleep(delay)\n    batch.mark_stalled(\"pending_ocr\")"
