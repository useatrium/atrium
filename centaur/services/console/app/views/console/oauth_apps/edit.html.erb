<% title = @app.slug %>
<% content_for :title, "Edit #{title} · Centaur Console" %>

<div class="mb-8">
  <a href="<%= console_oauth_app_path(@app) %>" class="back-link">← back to App</a>
  <div class="mt-2 flex flex-wrap items-center gap-3">
    <h1 class="page-title">Edit <%= title %></h1>
    <span class="resource-badge">OAuth</span>
  </div>
</div>

<%= render "errors", app: @app %>
<%= render "form", app: @app %>
