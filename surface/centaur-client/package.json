{
  "name": "@atrium/centaur-client",
  "version": "0.1.0",
  "description": "Typed Centaur control-plane client and durable event-stream reducer.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useatrium/atrium.git",
    "directory": "surface/centaur-client"
  },
  "bugs": {
    "url": "https://github.com/useatrium/atrium/issues"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "effect": "^3.21.4"
  }
}
