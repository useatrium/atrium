# Local operator defaults for Fly preview spikes.
#
# Copy to a local shell/session; do not commit real tokens.

FLY_ORG=personal
ATRIUM_PREVIEW_REGION=iad
ATRIUM_PREVIEW_TTL_HOURS=24

# Optional. If omitted, previewctl resolves origin from git.
ATRIUM_PREVIEW_REPO=useatrium/atrium

# Existing Atrium branches currently sign S3 requests with us-east-1. For AWS
# S3, use a us-east-1 bucket unless the target branch has configurable S3 region
# support.
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_BUCKET=atrium-preview-files-shared
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Required by Fly tooling, normally provided by `flyctl auth login`.
# FLY_API_TOKEN=
